# Copy this file to `.env.ios` before building the iOS app.
# Simulator can usually reach the Mac backend with localhost.
# Real iPhone builds cannot use localhost, because localhost means the iPhone itself.
#
# Temporary real-device testing on the same Wi-Fi can use your Mac LAN IP, for example:
# VITE_API_BASE_URL=http://10.85.68.192:8010
#
# App Store / TestFlight should use a reachable HTTPS API domain.
VITE_API_BASE_URL=http://localhost:8010
