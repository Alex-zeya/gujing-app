{
  "name": "gujing-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "backend": "backend/.venv/bin/python -m uvicorn main:app --reload --reload-exclude 'backend/.venv/*' --host 0.0.0.0 --port 8010 --app-dir backend",
    "backend:test": "backend/.venv/bin/python -m unittest discover -s backend/tests",
    "readiness": "node scripts/check-readiness.mjs",
    "dev": "vite",
    "test:e2e": "playwright test",
    "build": "vite build",
    "build:ios": "vite build --mode ios",
    "lint": "eslint .",
    "preview": "vite preview",
    "ios:add": "cap add ios",
    "ios:sync": "npm run build:ios && cap sync ios",
    "ios:open": "cap open ios",
    "ios:copy": "npm run build:ios && cap copy ios",
    "ios:devices": "xcrun xctrace list devices"
  },
  "dependencies": {
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.12"
  }
}
