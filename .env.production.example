# Backend
APP_ENV=production
PORT=8010

# Comma-separated allowed frontend/app origins.
# Keep capacitor/gujing origins for iOS WebView builds.
CORS_ORIGINS=https://your-frontend-domain.example,capacitor://localhost,ionic://localhost,gujing://localhost

# SQLite path. On cloud platforms, point this at a persistent disk if available.
GUJING_DB_PATH=/data/gujing.db

# SMS provider. Use mock only for testing.
SMS_PROVIDER=mock

# Tushare token for historical K-line data.
TUSHARE_TOKEN=

# Optional real SMS provider variables.
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=

# Optional WeChat login.
WECHAT_APP_ID=
WECHAT_APP_SECRET=
